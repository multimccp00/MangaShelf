# Virtualenv + bytecode — never commit.
.venv/
__pycache__/
*.py[cod]

# Editor/agent workspace settings — machine-local.
.claude/

# App runtime data (lives in ~/.mangashelf, but guard against strays).
*.db
*.db-journal
*.db-wal
*.log

# Personal / machine-specific files at the project root (leading / = root only,
# so e.g. web/static icons are unaffected):
#  - run-remote.bat hardcodes this machine's tailnet address
#  - portfolio material and loose images aren't part of the app
/run-remote.bat
/PORTFOLIO.md
/portfolio-shots/
/*.png
